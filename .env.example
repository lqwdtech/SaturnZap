# SaturnZap — Environment Variables
# Copy to .env and fill in your values.

# ── Required ──────────────────────────────────────────────
# Passphrase to encrypt/decrypt the BIP39 seed on disk.
# Set this before running any sz command.
SZ_PASSPHRASE=your-secure-passphrase-here

# ── Network ───────────────────────────────────────────────
# Default: bitcoin (mainnet). Use signet for testing with free test coins.
# SZ_NETWORK=bitcoin
# SZ_NETWORK=signet

# ── Spending Caps ─────────────────────────────────────────
# Global per-request spending cap for MCP l402_fetch tool (in sats).
# Strongly recommended for autonomous agents.
# SZ_MCP_MAX_SPEND_SATS=1000

# ── Mainnet Safety ────────────────────────────────────────
# Skip mainnet confirmation prompts (for automation pipelines only).
# SZ_MAINNET_CONFIRM=yes

# ── LQWD Region ──────────────────────────────────────────
# Force a specific LQWD LSP region (auto-detects from timezone by default).
# Options: CA, US, SE, FR, GB, JP, AU, BR, BH, SG, ZA, HK, KR, ID, IE, IT, DE, IN
# SZ_REGION=US

# ── Display ───────────────────────────────────────────────
# Pretty-print JSON output (for human debugging, not agent use).
# SZ_PRETTY=0

# ── Esplora Override ──────────────────────────────────────
# Custom Esplora server. If unset, SaturnZap probes public endpoints:
#   mainnet: blockstream.info/api → mempool.space/api
#   signet:  mempool.space/signet/api → blockstream.info/signet/api
#
# Public Esplora servers:
#   Mainnet:  https://blockstream.info/api
#             https://mempool.space/api
#   Signet:   https://mempool.space/signet/api
#             https://blockstream.info/signet/api
#   Testnet:  https://mempool.space/testnet/api
#             https://blockstream.info/testnet/api
#
# SZ_ESPLORA_URL=https://blockstream.info/api
