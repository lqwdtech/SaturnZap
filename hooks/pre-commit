#!/usr/bin/env bash
# SaturnZap — pre-commit hook
# 1. Checks that docs/ or README.md are updated alongside code changes.
# 2. Runs the security scanner on staged Python files.
# Blocks commit if CRITICAL or HIGH severity findings are detected.
#
# Setup: git config core.hooksPath hooks

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
PROFILE="security/profiles/saturnzap.yaml"
SCANNER="security/security_scan.py"

# ── Documentation check ──────────────────────────────────────────
# If src/ code is staged, require docs/ or README.md to also be staged.

STAGED_SRC=$(git diff --cached --name-only --diff-filter=ACMR -- 'src/*.py' 2>/dev/null || true)
STAGED_DOCS=$(git diff --cached --name-only --diff-filter=ACMR -- 'docs/*' 'README.md' 2>/dev/null || true)

if [[ -n "$STAGED_SRC" && -z "$STAGED_DOCS" ]]; then
    echo ""
    echo "══════════════════════════════════════════════════════════════"
    echo "  COMMIT BLOCKED — documentation not updated"
    echo ""
    echo "  You are committing changes to src/ but neither docs/ nor"
    echo "  README.md have been staged."
    echo ""
    echo "  Update the relevant docs then:"
    echo "    git add docs/ README.md"
    echo ""
    echo "  To skip this check (emergency only):"
    echo "    git commit --no-verify"
    echo "══════════════════════════════════════════════════════════════"
    echo ""
    exit 1
fi

# ── Security scan ────────────────────────────────────────────────
# Only runs when .py files are staged.

STAGED_PY=$(git diff --cached --name-only --diff-filter=ACMR -- '*.py')

if [[ -z "$STAGED_PY" ]]; then
    echo "pre-commit: no staged Python files — skipping security scan"
    exit 0
fi

# Check that scanner and profile exist
if [[ ! -f "$PROJECT_ROOT/$SCANNER" ]]; then
    echo "pre-commit: scanner not found at $SCANNER — skipping"
    exit 0
fi

if [[ ! -f "$PROJECT_ROOT/$PROFILE" ]]; then
    echo "pre-commit: profile not found at $PROFILE — skipping"
    exit 0
fi

echo "pre-commit: running security scan on $(echo "$STAGED_PY" | wc -w) staged file(s)..."

# Run the scanner with --files for staged-only scanning
# shellcheck disable=SC2086
python3 "$PROJECT_ROOT/$SCANNER" \
    --profile "$PROJECT_ROOT/$PROFILE" \
    --files $STAGED_PY

EXIT_CODE=$?

if [[ $EXIT_CODE -ne 0 ]]; then
    echo ""
    echo "══════════════════════════════════════════════════════════════"
    echo "  COMMIT BLOCKED — security scan found CRITICAL/HIGH issues"
    echo "  Fix the findings above, then try again."
    echo "══════════════════════════════════════════════════════════════"
    echo ""
    exit 1
fi

exit 0
